# Copy to .env.local and fill in. Never commit real values.

# ---- Firebase Web SDK (public; shipped to the browser) ----
# From Firebase console → Project settings → Your apps → SDK setup & config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin SDK (server only; keep secret) ----
# A service-account key JSON, on a single line.
# Firebase console → Project settings → Service accounts → Generate new private key.
FIREBASE_SERVICE_ACCOUNT_KEY=

# ---- LLM provider (server only) ----
# Which provider the server route calls: "gemini" (default), "anthropic", or "openai".
LLM_PROVIDER=gemini

# Google Gemini (used when LLM_PROVIDER=gemini).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Optional: timeout for a single analysis call, in milliseconds (default 45000).
# LLM_TIMEOUT_MS=45000

rules_version = '2';

// Security model: server-mediated writes.
// - All writes to `analyses` happen on the server via the Firebase Admin SDK,
//   which bypasses these rules. Clients are never permitted to write.
// - Clients may READ only their own documents. Because list queries are
//   evaluated per-document, a client query MUST constrain `userId == auth.uid`
//   (the app always does) or the whole query is denied. A malicious client
//   querying the collection directly cannot read another user's data.
service cloud.firestore {
  match /databases/{database}/documents {

    match /analyses/{analysisId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
